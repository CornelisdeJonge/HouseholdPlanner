@page
<h1 class="text-2xl font-semibold mb-4">Household Planner</h1>

<p class="text-sm text-slate-300 mb-4">
    Tailwind 4 and HTMX are wired up. This is your starting dashboard.
</p>

<button class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 rounded text-sm font-medium"
        hx-get="/healthz"
        hx-target="#health-status"
        hx-swap="innerHTML">
    Check health
</button>

<div id="health-status" class="mt-2 text-xs text-slate-400"></div>