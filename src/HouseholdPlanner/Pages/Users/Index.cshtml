@page
@model HouseholdPlanner.Pages.Users.IndexModel

@{
    ViewData["Title"] = "Users";
}

<section class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="page-title">
            Users
        </h1>

        <a asp-page="Create" class="btn btn-primary">
            + Add user
        </a>
    </div>

    @if (Model.Users.Count == 0)
    {
        <p class="text-muted text-sm">
            No users yet. Create the first user for your household.
        </p>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Color</th>
                        <th>Sort order</th>
                        <th>Active</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                @user.Name
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(user.Color))
                                {
                                    <div class="flex items-center gap-2">
                                        <span class="inline-block h-4 w-4 rounded-full border"
                                              style="background-color: @user.Color; border-color: var(--color-border);">
                                        </span>
                                        <span class="text-muted text-xs">@user.Color</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted text-xs">—</span>
                                }
                            </td>

                            <td>
                                @(user.SortOrder?.ToString() ?? "—")
                            </td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge">Active</span>
                                }
                                else
                                {
                                    <span class="badge">Inactive</span>
                                }
                            </td>

                            <td class="text-right">
                                <div class="inline-flex gap-2">
                                    <a asp-page="Edit"
                                           asp-route-id="@user.Id"
                                           class="action-link">
                                        Edit
                                    </a>

                                    <a asp-page="Delete"
                                           asp-route-id="@user.Id"
                                           class="action-link">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>