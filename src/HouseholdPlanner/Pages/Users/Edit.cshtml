@page
@model HouseholdPlanner.Pages.Users.EditModel

@{
    ViewData["Title"] = "Edit user";
    var initialColor = string.IsNullOrWhiteSpace(Model.PlannerUser?.Color) ? "#3B82F6" : Model.PlannerUser.Color;
}

<section class="space-y-4">
    <h1 class="page-title">
        Edit user
    </h1>

    <section class="panel">
        <div class="panel-body">
            <form method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PlannerUser.Id" />

                <div asp-validation-summary="ModelOnly" class="validation"></div>

                <div class="space-y-1">
                    <label asp-for="PlannerUser.Name" class="label"></label>

                    <input asp-for="PlannerUser.Name" class="input" />

                    <span asp-validation-for="PlannerUser.Name" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="PlannerUser.Color" class="label"></label>

                    <div class="flex items-center gap-3">
                        <input type="color"
                               value="@initialColor"
                               class="colorhex-picker h-10 w-14 rounded border bg-transparent p-1"
                               style="border-color: var(--color-border);"
                               aria-label="Pick a color" />

                        <input asp-for="PlannerUser.Color"
                               type="text"
                               placeholder="#3B82F6"
                               class="input colorhex-text flex-1" />
                    </div>

                    <span asp-validation-for="PlannerUser.Color" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="PlannerUser.SortOrder" class="label"></label>

                    <input asp-for="PlannerUser.SortOrder"
                           type="number"
                           class="input" />

                    <span asp-validation-for="PlannerUser.SortOrder" class="validation text-xs"></span>

                    <p class="text-muted text-xs">
                        Optional. Lower numbers appear first in lists.
                    </p>
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="PlannerUser.IsActive"
                           class="h-4 w-4 rounded" />

                    <label asp-for="PlannerUser.IsActive"
                           class="text-sm text-muted"></label>
                </div>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary">
                        Save
                    </button>

                    <a asp-page="Index" class="btn btn-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </section>
</section>

@section Scripts {
    <script>
        (function () {
            function wireColorHexSync(root) {
                var pickers = root.querySelectorAll('input.colorhex-picker');
                pickers.forEach(function (picker) {
                    var container = picker.closest('.flex');
                    if (!container) return;

                    var text = container.querySelector('input.colorhex-text');
                    if (!text) return;

                    picker.addEventListener('input', function () {
                        text.value = picker.value;
                    });

                    text.addEventListener('input', function () {
                        var v = text.value.trim();
                        var hex6 = /^#[0-9A-Fa-f]{6}$/;
                        if (hex6.test(v)) {
                            picker.value = v;
                        }
                    });
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                wireColorHexSync(document);
            });
        })();
    </script>
}
``