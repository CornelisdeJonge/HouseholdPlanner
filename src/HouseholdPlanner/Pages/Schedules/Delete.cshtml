@page
@model HouseholdPlanner.Pages.Schedules.DeleteModel

@{
    ViewData["Title"] = "Delete planned time";
}

<div class="max-w-xl mx-auto bg-white dark:bg-slate-900 shadow-lg rounded-xl border border-slate-200 dark:border-slate-700 p-6">
    <h1 class="text-2xl font-semibold text-red-600">
        Delete planned time
    </h1>

    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
        Are you sure you want to delete this planned time block?
    </p>

    <dl class="mt-4 text-sm text-slate-800 dark:text-slate-100 space-y-2">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-x-2">
            <dt class="font-medium text-slate-500 dark:text-slate-400 sm:w-24">
                Task
            </dt>
            <dd>
                @Model.Schedule.PlannerTask.Name
            </dd>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-x-2">
            <dt class="font-medium text-slate-500 dark:text-slate-400 sm:w-24">
                Date
            </dt>
            <dd>
                @Model.Schedule.Date.ToString("yyyy-MM-dd")
            </dd>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-x-2">
            <dt class="font-medium text-slate-500 dark:text-slate-400 sm:w-24">
                Time
            </dt>
            <dd>
                @Model.Schedule.StartLocalTime.ToString("HH\\:mm")
                –
                @Model.Schedule.StartLocalTime.Add(Model.Schedule.AmountOfTime).ToString("HH\\:mm")
            </dd>
        </div>
    </dl>

    <form method="post" class="mt-6 space-y-4">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Schedule.Id" />
        <input type="hidden" asp-for="ReturnUrl" />

        <div class="flex flex-wrap gap-3">
            <button type="submit"
                    class="inline-flex items-center justify-center rounded-md border border-transparent bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                Delete
            </button>

            <a href="@Model.ReturnUrl"
                   class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2">
                Cancel
            </a>
        </div>
    </form>
</div>