@page
@model HouseholdPlanner.Pages.Schedules.DeleteModel

@{
    ViewData["Title"] = "Delete planned time";
}

<div class="panel">
    <div class="panel-body">
        <h1 class="page-title text-danger">Delete planned time</h1>

        <p class="text-muted">
            Are you sure you want to delete this planned time block?
        </p>

        <dl class="mt-2 text-sm">
            <dt>Task</dt>
            <dd>@Model.Schedule.PlannerTask.Name</dd>
            <dt>Date</dt>
            <dd>@Model.Schedule.Date.ToString("yyyy-MM-dd")</dd>
            <dt>Time</dt>
            <dd>
                @Model.Schedule.StartLocalTime.ToString("HH\\:mm")
                –
                @Model.Schedule.StartLocalTime.Add(Model.Schedule.AmountOfTime).ToString("HH\\:mm")
            </dd>
        </dl>

        <form method="post" class="mt-4">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Schedule.Id" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="flex gap-2">
                <button type="submit" class="btn btn-primary">Delete</button>
                <a href="@Model.ReturnUrl" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>