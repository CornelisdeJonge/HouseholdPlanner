@page
@model HouseholdPlanner.Pages.Schedules.CreateModel

@{
    ViewData["Title"] = "Plan task time";
}

<div class="panel">
    <div class="panel-body">
        <h1 class="page-title">Plan task time</h1>

        <p class="text-muted">
            Task: <strong>@Model.TaskName</strong>
            @if (!string.IsNullOrEmpty(Model.AssigneeDisplay))
            {
                <span> · @Model.AssigneeDisplay</span>
            }
        </p>

        <form method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Input.TaskId" />
            <input type="hidden" asp-for="Input.ReturnUrl" />

            <div class="form-field">
                <label asp-for="Input.Date"></label>
                <input asp-for="Input.Date" type="date" class="form-input" />
                <span asp-validation-for="Input.Date" class="text-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.StartLocalTime"></label>
                <input asp-for="Input.StartLocalTime" type="time" class="form-input" step="1800" />
                <span asp-validation-for="Input.StartLocalTime" class="text-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.DurationMinutes"></label>
                <input asp-for="Input.DurationMinutes" type="number" class="form-input" min="30" step="30" />
                <p class="text-muted text-sm">Default 60 minutes; rounded to 30-minute steps.</p>
                <span asp-validation-for="Input.DurationMinutes" class="text-validation"></span>
            </div>

            <div class="mt-4 flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="@Model.Input.ReturnUrl" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}