@page
@model HouseholdPlanner.Models.ScheduleModel
@{
    ViewData["Title"] = "Plan task time";
}
<section class="space-y-4">
<div class="panel">
    <div class="panel-body">
        <h1 class="page-title">Schedule time for:</h1>

        <p class="text-muted p-2">
            <span>Task: </span> <strong>@Model.TaskName</strong>
            @if (!string.IsNullOrEmpty(Model.AssigneeDisplay))
            {
                <span> · @Model.AssigneeDisplay</span>
            }
        </p>

        <form method="post" class="space-y-4">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Input.TaskId" />
        <input type="hidden" asp-for="Input.ReturnUrl" />

        <div class="space-y-1">
            <label asp-for="Input.Date" class="label"></label>
            <input asp-for="Input.Date" type="date" class="input" />
            <span asp-validation-for="Input.Date" class="validation text-xs"></span>
        </div>

        <div class="space-y-1">
            @await Html.PartialAsync("_TimePicker", Model)
        </div>

        <div class="space-y-1">
            <label asp-for="Input.DurationMinutes" class="label"></label>
            <input asp-for="Input.DurationMinutes" type="number" class="input" min="30" step="30" />
            <p class="text-muted text-sm">Default 60 minutes; rounded to 30-minute steps.</p>
            <span asp-validation-for="Input.DurationMinutes" class="validation text-xs"></span>
        </div>

        <div class="mt-4 flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="@Model.Input.ReturnUrl" class="btn btn-secondary">Cancel</a>
        </div>
        </form>
    </div>
</div>
</section>
@section Scripts {
    <script>
        (function () {
            const hour = document.getElementsByName("StartLocalTime_Hour")[0];
            const minute = document.getElementsByName("StartLocalTime_Minute")[0];
            const hidden = document.getElementById("hiddenStartLocalTime");

            function updateHidden() {
                hidden.value = `${hour.value}:${minute.value}`;
            }

            hour.addEventListener("change", updateHidden);
            minute.addEventListener("change", updateHidden);

            updateHidden();
        })();
    </script>
}