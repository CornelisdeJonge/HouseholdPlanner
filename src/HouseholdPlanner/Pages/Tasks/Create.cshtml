@page
@model HouseholdPlanner.Pages.Tasks.CreateModel
@using HouseholdPlanner.Data.Entities
@{
    ViewData["Title"] = "Create Task";
}

<h1 class="mb-4 text-xl font-semibold">Create Task</h1>

<div class="panel rounded-xl p-4">
    <form method="post" class="space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

        <div>
            <label asp-for="TaskItem.Name" class="form-label"></label>
            <input asp-for="TaskItem.Name" class="input mt-1" />
            <span asp-validation-for="TaskItem.Name" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="TaskItem.Description" class="form-label"></label>
            <textarea asp-for="TaskItem.Description" rows="3" class="textarea mt-1"></textarea>
            <span asp-validation-for="TaskItem.Description" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="TaskItem.AssignedUserId" class="form-label">Assigned to</label>
            <select asp-for="TaskItem.AssignedUserId"
                    asp-items="Model.UserOptions"
                    class="select mt-1">
                <option value="">Unassigned</option>
            </select>
        </div>

        <div>
            <label asp-for="TaskItem.Priority" class="form-label"></label>
            <select asp-for="TaskItem.Priority"
                    asp-items="Html.GetEnumSelectList<TaskPriority>()"
                    class="select mt-1"></select>
        </div>

        <div>
            <label asp-for="TaskItem.Deadline" class="form-label"></label>
            <input asp-for="TaskItem.Deadline" type="date" class="input mt-1" />
        </div>

        <div class="flex items-center gap-3">
            <button type="submit" class="btn btn-primary">
                Save
            </button>
            <a asp-page="./Index" class="btn btn-secondary">
                Cancel
            </a>
        </div>
    </form>
</div>