@page
@model HouseholdPlanner.Pages.Tasks.CreateModel
@using HouseholdPlanner.Data.Entities

@{
    ViewData["Title"] = "Create task";
}

<section class="space-y-4">
    <h1 class="page-title">Create task</h1>

    <section class="panel">
        <div class="panel-body">
            <form method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="validation"></div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Name" class="label"></label>
                    <input asp-for="TaskItem.Name" class="input" />
                    <span asp-validation-for="TaskItem.Name" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Description" class="label"></label>
                    <textarea asp-for="TaskItem.Description" rows="3" class="textarea"></textarea>
                    <span asp-validation-for="TaskItem.Description" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.AssignedUserId" class="label">Assigned to</label>
                    <select asp-for="TaskItem.AssignedUserId"
                            asp-items="Model.UserOptions"
                            class="select">
                        <option value="">Unassigned</option>
                    </select>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Priority" class="label"></label>
                    <select asp-for="TaskItem.Priority"
                            asp-items="Html.GetEnumSelectList<TaskPriority>()"
                            class="select"></select>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Deadline" class="label"></label>
                    <input asp-for="TaskItem.Deadline" type="date" class="input" />
                </div>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary">
                        Save
                    </button>

                    <a asp-page="./Index" class="btn btn-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </section>
</section>