@page "{id:int}"
@model HouseholdPlanner.Pages.Tasks.DeleteModel

@{
    ViewData["Title"] = "Delete task";
}

<section class="space-y-4">
    <h1 class="page-title">Delete task</h1>

    <section class="panel">
        <div class="panel-body">
            <div class="mb-4 space-y-3">
                <p class="text-muted text-sm">Are you sure you want to delete this task?</p>

                <div class="rounded-xl border p-3 text-sm"
                     style="border-color: var(--color-danger); background-color: color-mix(in srgb, var(--color-danger) 10%, var(--color-surface)); color: var(--color-text);">
                    <div class="font-semibold">@Model.TaskItem.Name</div>

                    @if (!string.IsNullOrWhiteSpace(Model.TaskItem.Description))
                    {
                        <div class="mt-1 text-xs text-muted">@Model.TaskItem.Description</div>
                    }
                </div>
            </div>

            <form method="post" class="flex items-center gap-3">
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-page="./Index" class="btn btn-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </section>
</section>