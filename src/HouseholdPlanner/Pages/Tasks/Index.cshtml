@page
@model HouseholdPlanner.Pages.Tasks.IndexModel

@{
    ViewData["Title"] = "Tasks";
}

<section class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="page-title">Tasks</h1>

        <a asp-page="./Create" class="btn btn-primary">
            New task
        </a>
    </div>

    @if (!Model.Tasks.Any())
    {
        <p class="text-muted text-sm">
            No tasks yet. Create the first task for your household.
        </p>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Assigned</th>
                        <th>Priority</th>
                        <th>Deadline</th>
                        <th>Subtasks</th>
                        <th><div class="text-right">Actions</div> </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        var doneCount = task.Subtasks.Count(s => s.IsDone);
                        var totalCount = task.Subtasks.Count;

                        <tr>
                            <td>
                                <div class="font-medium">@task.Name</div>

                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <div class="text-muted text-xs">@task.Description</div>
                                }
                            </td>

                            <td>
                                @if (task.Assignee is null)
                                {
                                    <span class="text-muted text-xs">Unassigned</span>
                                }
                                else
                                {
                                    <span class="badge">
                                        @task.Assignee.Name
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="badge">
                                    @task.Priority
                                </span>
                            </td>

                            <td>
                                @if (task.Deadline.HasValue)
                                {
                                    @task.Deadline.Value.ToString("yyyy-MM-dd")
                                }
                                else
                                {
                                    <span class="text-muted text-xs">None</span>
                                }
                            </td>

                            <td class="text-sm">
                                @if (totalCount == 0)
                                {
                                    <span class="text-muted">No subtasks</span>
                                }
                                else
                                {
                                    <span>@doneCount / @totalCount done</span>
                                }
                            </td>

                            <td class="whitespace-nowrap text-right">
                                <div class="inline-flex gap-3">
                                    <a asp-page="./Edit"
                                           asp-route-id="@task.Id"
                                           class="action-link">
                                        Edit
                                    </a>

                                    <a asp-page="./Delete"
                                           asp-route-id="@task.Id"
                                           class="action-link">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>