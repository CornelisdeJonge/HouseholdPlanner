@page "{id:int}"
@model HouseholdPlanner.Pages.Tasks.EditModel
@using HouseholdPlanner.Data.Entities

@{
    ViewData["Title"] = "Edit task";
}

<section class="space-y-6">
    <h1 class="page-title">Edit task</h1>

    <section class="panel">
        <div class="panel-body">
            <form method="post" class="space-y-4">
                <input type="hidden" asp-for="TaskItem.Id" />

                <div asp-validation-summary="ModelOnly" class="validation"></div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Name" class="label"></label>
                    <input asp-for="TaskItem.Name" class="input" />
                    <span asp-validation-for="TaskItem.Name" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Description" class="label"></label>
                    <textarea asp-for="TaskItem.Description" rows="3" class="textarea"></textarea>
                    <span asp-validation-for="TaskItem.Description" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Priority" class="label"></label>
                    <select asp-for="TaskItem.Priority"
                            asp-items="Html.GetEnumSelectList<TaskPriority>()"
                            class="select"></select>
                    <span asp-validation-for="TaskItem.Priority" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.Deadline" class="label"></label>
                    <input asp-for="TaskItem.Deadline" type="date" class="input" />
                    <span asp-validation-for="TaskItem.Deadline" class="validation text-xs"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="TaskItem.AssigneeId" class="label">Assignee</label>
                    <select asp-for="TaskItem.AssigneeId"
                            asp-items="Model.UserOptions"
                            class="form-input">
                        <option value="">— Unassigned —</option>
                    </select>
                    <span asp-validation-for="TaskItem.AssigneeId" class="validation text-xs"></span>
                </div>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a asp-page="./Index" class="btn btn-secondary">Back to list</a>
                </div>
            </form>
        </div>
    </section>
    <section class="space-y-3">
        <h2 class="text-lg font-semibold">Subtasks</h2>

        <section class="panel">
            <div class="panel-body">
                @if (Model.TaskItem.Subtasks == null || !Model.TaskItem.Subtasks.Any())
                {
                    <p class="text-muted text-sm">No subtasks yet.</p>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var sub in Model.TaskItem.Subtasks.OrderBy(s => s.Id))
                        {
                            <li class="flex items-center">
                                <form method="post" asp-page-handler="ToggleSubtask" class="inline-flex items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="subtaskId" value="@sub.Id" />
                                    <input type="checkbox"
                                           class="h-5 w-5 rounded"
                                    @(sub.IsDone ? "checked" : "")
                                           hx-post="?handler=ToggleSubtask"
                                           hx-trigger="change"
                                           hx-include="closest form"
                                           hx-swap="none" />
                                    <span class="text-sm @(sub.IsDone ? "text-muted line-through" : "")">
                                        @sub.Name
                                    </span>
                                </form>
                            </li>
                        }
                    </ul>
                }

                <form method="post" asp-page-handler="AddSubtask" class="mt-4 flex items-center gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.TaskItem.Id" />

                    <input type="text"
                           name="newSubtaskTitle"
                           class="input flex-1"
                           placeholder="New subtask title" />
                    <button type="submit" class="btn btn-secondary">
                        Add subtask
                    </button>
                </form>
            </div>
        </section>
    </section>
</section>