@using System
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

    string NavClass(string targetPage) =>
        string.Equals(page, targetPage, StringComparison.OrdinalIgnoreCase)
            ? "nav-link nav-link-active"
            : "nav-link";
}

<!DOCTYPE html>
<html lang="en" id="themeRoot" class="theme-light">
<head>
    <meta charset="utf-8" />
    <title>@(ViewData["Title"] ?? "Household Planner")</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <script>
            (function () {
                const saved = localStorage.getItem("theme");
                const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                const theme = saved === "dark" || saved === "light"
                    ? saved
                    : (systemPrefersDark ? "dark" : "light");

                const root = document.documentElement;
                root.classList.remove("theme-light", "theme-dark");
                root.classList.add(theme === "dark" ? "theme-dark" : "theme-light");
                root.style.colorScheme = theme;
            })();
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>

<body class="min-h-screen transition-colors duration-300">
    <div class="mx-auto flex min-h-screen max-w-screen-md flex-col">

        <!-- Header -->
        <header class="app-header">
            <div class="px-4 pt-3">
                <div class="flex items-center justify-between">

                    <!-- Title -->
                    <div class="text-base font-semibold tracking-tight">
                        Household Planner
                    </div>

                    <!-- Weekly label + theme toggle -->
                    <div class="flex items-center gap-3">

                        <div class="text-muted text-[11px] uppercase tracking-wide">
                            Weekly
                        </div>

                        <!-- Theme toggle button -->
                        <button id="themeToggle"
                                type="button"
                                class="theme-toggle"
                                onclick="toggleTheme()"
                                aria-label="Toggle theme"
                                aria-pressed="false">
                            🌓
                        </button>

                    </div>

                </div>
            </div>

            <!-- Top navigation -->
            <nav class="mt-3 px-3 pb-2">
                <div class="flex gap-2 overflow-x-auto">

                    <a asp-page="/Index" class="@(NavClass("/Index"))">Week</a>
                    <a asp-page="/Users/Index" class="@(NavClass("/Users/Index"))">Users</a>
                    <a asp-page="/Tasks/Index" class="@(NavClass("/Tasks/Index"))">Tasks</a>
                    <a asp-page="/Meals/Index" class="@(NavClass("/Meals/Index"))">Meals</a>
                    <a asp-page="/Availability/Index" class="@(NavClass("/Availability/Index"))">Availability</a>

                </div>
            </nav>

        </header>

        <!-- Main content -->
        <main class="flex-1 px-4 pb-4 pt-3">
            @RenderBody()
        </main>
    </div>

    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>