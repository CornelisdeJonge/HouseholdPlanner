@using System
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

    string NavClass(string targetPage) =>
        string.Equals(page, targetPage, StringComparison.OrdinalIgnoreCase)
            ? "btn btn-primary whitespace-nowrap"
            : "btn btn-secondary whitespace-nowrap";
}

<!DOCTYPE html>
<html lang="en" class="theme-light">
<head>
    <meta charset="utf-8" />
    <title>@(ViewData["Title"] ?? "Household Planner")</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <script>
            (function () {
                const storageKey = "theme";
                const saved = localStorage.getItem(storageKey);
                const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                const theme = saved === "dark" || saved === "light"
                    ? saved
                    : (systemPrefersDark ? "dark" : "light");

                const root = document.documentElement;
                root.classList.remove("theme-light", "theme-dark");
                root.classList.add(theme === "dark" ? "theme-dark" : "theme-light");
                root.setAttribute("data-theme", theme);
            })();
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-inner">
                <div class="flex items-center justify-between gap-4">
                    <div class="text-base font-semibold tracking-tight">
                        Household Planner
                    </div>
                    <div class="flex items-center gap-3">
                        <nav class="mt-1">
                                <div class="flex gap-2 overflow-x-auto pb-1">
                                    <a asp-page="/Index" class="@(NavClass("/Index"))">Week</a>
                                    <a asp-page="/Users/Index" class="@(NavClass("/Users/Index"))">Users</a>
                                    <a asp-page="/Tasks/Index" class="@(NavClass("/Tasks/Index"))">Tasks</a>
                                    <a asp-page="/Meals/Index" class="@(NavClass("/Meals/Index"))">Meals</a>
                                    <a asp-page="/Availability/Index" class="@(NavClass("/Availability/Index"))">Availability</a>
                                </div>
                        </nav>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="text-muted text-[11px] uppercase tracking-wide">
                            Weekly
                        </div>

                        <button type="button"
                                class="btn btn-secondary"
                                data-theme-toggle
                                aria-label="Toggle theme"
                                aria-pressed="false">
                            <span aria-hidden="true">🌓</span>
                            <span data-theme-label class="hidden sm:inline">Dark mode</span>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <main class="app-main">
            @RenderBody()
        </main>
    </div>

    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>