@model HouseholdPlanner.Pages.IndexModel

<div class="page-header flex flex-col gap-2">

    <!-- TOP ROW: User selector chips + week navigation -->
    <div class="flex flex-wrap items-center justify-between gap-2">

        <!-- USER SELECTOR CHIPS -->
        <div class="flex flex-wrap gap-2">
            <!-- ALL USERS -->
            <a class="btn btn-secondary text-xs @(Model.SelectedUserId == null ? "ring-2" : "")"
                   asp-page="./Index"
                   asp-route-weekStart='@Model.WeekStart.ToString("yyyy-MM-dd")'>
                All
            </a>

            <!-- PER-USER BUTTONS -->
            @foreach (var user in Model.AllUsers)
            {
                var isSelected = Model.SelectedUserId == user.Id;

                <a class="btn user-chip text-xs @(isSelected ? "ring-2 ring-offset-2" : "")"
                       style="--user-chip-color:@user.Color"
                       asp-page="./Index"
                       asp-route-userId="@user.Id"
                       asp-route-weekStart='@Model.WeekStart.ToString("yyyy-MM-dd")'>
                    @user.Name
                </a>
            }
        </div>

        <!-- WEEK NAVIGATION -->
        <div class="flex items-center gap-2">
            <a class="btn btn-secondary"
                   asp-page="./Index"
                   asp-route-userId="@Model.SelectedUserId"
                   asp-route-weekStart='@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")'>
                ◀ Previous
            </a>

            <a class="btn btn-secondary"
                   asp-page="./Index"
                   asp-route-userId="@Model.SelectedUserId"
                   asp-route-weekStart='@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")'>
                Next ▶
            </a>

            <a class="btn btn-secondary"
                   asp-page="./Index"
                   asp-route-userId="@Model.SelectedUserId">
                Today
            </a>
        </div>
    </div>
</div>

<!-- WEEK CALENDAR GRID -->
<div class="week-grid border rounded overflow-hidden mt-2">

    <!-- HEADER ROW (fixed) -->
    <div class="grid grid-cols-[minmax(36px,50px)_repeat(7,1fr)]">

        <!-- TIME HEADER -->
        <div class="border-r">
            <div class="border-b px-1 py-1 text-center h-full"></div>
        </div>

        <!-- DAY HEADERS -->
        @foreach (var day in Model.Days)
        {
            <div class="border-r last:border-r-0">
                <div class="border-b px-1 py-1 text-center">
                    <div class="text-xs text-muted">@day.ToString("dd MMM")</div>
                    <div class="font-semibold">@day.ToString("ddd")</div>
                </div>
            </div>
        }
    </div>

    <!-- SCROLLABLE AREA -->
    <div class="overflow-y-auto max-h-[calc(100vh-220px)]">
        <div class="grid grid-cols-[minmax(36px,50px)_repeat(7,1fr)]">

            <!-- TIME COLUMN BODY (scrolls vertically with days) -->
            <div class="border-r">
                @foreach (var time in Model.HourSlots)
                {
                    var blockHeightPx = 24; // each 30-min slot
                    <div class="border-t text-xs text-muted pr-2 text-right flex items-start justify-end pt-1" style="height:@(blockHeightPx)px;">
                        @time.ToString("HH\\:mm")
                    </div>
                    <div class="background-row-alternate text-xs text-muted pr-2 text-right flex items-start justify-end pt-1" style="height:@(blockHeightPx)px;">
                        @time.AddMinutes(30).ToString("HH\\:mm")
                    </div>
                }
            </div>

            <!-- DAY COLUMNS -->
            @foreach (var day in Model.Days)
            {
                var dayBlocks = Model.ScheduleBlocks
                    .Where(b => b.Date == day)
                    .OrderBy(b => b.StartTimeIndex)
                    .ToList();

                var totalRows = Model.HourSlots.Count * 4;
                var blockHeightPx = 12; // each 15-min slot

                <div class="border-r last:border-r-0 min-w-0">

                    <!-- Relative container: background rows + absolutely positioned blocks -->
                    <div class="relative" style="height:@(totalRows * blockHeightPx)px;">

                        <!-- Background rows -->
                        @for (var l = 0; l < totalRows; l++)
                        {
                            bool isHourLine = l % 4 == 0;
                            bool isHalfHour = l % 4 < 2;
                            <div class="@(isHourLine ? "border-t" : "") w-full @(isHalfHour ? "background-row" : "background-row-alternate")"
                                 style="height:@(blockHeightPx)px;"></div>
                        }

                        <!-- SEGMENTED BLOCK OVERLAY -->
                        @{
                            int i = 0;

                            List<IndexModel.TaskScheduleBlockViewModel> GetActiveBlocks(int rowIndex) =>
                                dayBlocks
                                    .Where(b => b.StartTimeIndex <= rowIndex &&
                                                (b.StartTimeIndex + b.BlockSpan) > rowIndex)
                                    .OrderBy(b => b.StartTimeIndex)
                                    .ToList();

                            bool SameSet(List<IndexModel.TaskScheduleBlockViewModel> a,
                                         List<IndexModel.TaskScheduleBlockViewModel> b)
                            {
                                if (a.Count != b.Count) return false;
                                return a.Select(x => x.Id).OrderBy(x => x)
                                        .SequenceEqual(b.Select(x => x.Id).OrderBy(x => x));
                            }

                            while (i < totalRows)
                            {
                                var overlapping = GetActiveBlocks(i);

                                if (!overlapping.Any())
                                {
                                    i++;
                                    continue;
                                }

                                var j = i + 1;
                                while (j < totalRows)
                                {
                                    var next = GetActiveBlocks(j);
                                    if (!SameSet(overlapping, next))
                                        break;

                                    j++;
                                }

                                var spanRows = j - i;
                                var topPx = i * blockHeightPx;
                                var heightPx = spanRows * blockHeightPx;

                                if (overlapping.Count == 1)
                                {
                                    var block = overlapping[0];
                                    var blocks = Math.Max(1, spanRows);

                                    var borderColor = !string.IsNullOrEmpty(block.AssigneeColor)
                                        ? block.AssigneeColor
                                        : "var(--planner-border-subtle, rgba(148, 163, 184, 0.7))";

                                    var tooltip = $"{block.TaskName} • {block.AssigneeName} • {block.StartLocalTime:HH\\:mm}–{block.StartLocalTime.Add(block.Duration):HH\\:mm}";

                                    <a href="@Url.Page("/Schedules/Edit",
                                        new
                                        {
                                            id = block.Id,
                                            returnUrl = Url.Page("/Index", new
                                        {
                                                weekStart = Model.WeekStart.ToString("yyyy-MM-dd"),
                                                userId = Model.SelectedUserId
                                            })
                                        })"
                                        class="schedule-block @(block.IsDoubleBooked ? "schedule-block--double-booked" : "")"
                                        title="@tooltip"
                                        style="
                                        --user-chip-color:@borderColor;
                                        position:absolute;
                                        top:@(topPx)px;
                                        height:@(heightPx)px;
                                        left:0;
                                        right:0;
                                        border-color:@borderColor;
                                        overflow:hidden;">

                                        <div class="schedule-block__title overflow-hidden text-ellipsis whitespace-nowrap"
                                             title="@tooltip">
                                            @block.TaskName
                                        </div>

                                        @if (blocks >= 4 && !string.IsNullOrEmpty(block.AssigneeName))
                                        {
                                            <div class="schedule-block__meta text-muted text-xs overflow-hidden text-ellipsis whitespace-nowrap"
                                                 title="@tooltip">
                                                @block.AssigneeName
                                            </div>
                                        }

                                        @if (blocks >= 6)
                                        {
                                            <div class="schedule-block__meta text-muted text-xs overflow-hidden text-ellipsis whitespace-nowrap"
                                                 title="@tooltip">
                                                @block.StartLocalTime.ToString("HH\\:mm")
                                                –
                                                @block.StartLocalTime.Add(block.Duration).ToString("HH\\:mm")
                                            </div>
                                        }
                                    </a>
                                }
                                else
                                {
                                    var combinedTooltip = string.Join(" | ",
                                        overlapping.Select(b =>
                                            $"{b.TaskName} • {b.AssigneeName} • {b.StartLocalTime:HH\\:mm}–{b.StartLocalTime.Add(b.Duration):HH\\:mm}"));

                                    <div class="schedule-block schedule-block--overlap"
                                         title="@combinedTooltip"
                                         style="
                                        position:absolute;
                                        top:@(topPx)px;
                                        height:@(heightPx)px;
                                        left:0;
                                        right:0;">
                                        <div class="schedule-block__title overflow-hidden text-ellipsis whitespace-nowrap">
                                            @($"{overlapping.Count} overlapping tasks")
                                        </div>
                                    </div>
                                }

                                i = j;
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>