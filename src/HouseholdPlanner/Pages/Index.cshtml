@page
@model HouseholdPlanner.Pages.IndexModel

@{
    ViewData["Title"] = "Week";
}

@if (TempData["OutsideAvailabilityWarning"] is string warn)
{
    <div class="panel mb-4">
        <div class="panel-body">
            <p class="text-sm">@warn</p>
        </div>
    </div>
}

<div class="page">
    <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,3fr)_minmax(0,1.5fr)]">

        <!-- LEFT: Week calendar (header + grid) via partial -->
        <section class="panel">
            <div class="panel-body">
                <partial name="_WeekCalendar" model="Model" />
            </div>
        </section>

        <!-- RIGHT: Sidebar (tasks summary) - stays here for now -->
        <aside class="panel">
            <div class="panel-body">
                <partial name="_WeekSidebar" model="Model" />
            </div>
        </aside>
    </div>
</div>