@page
@model HouseholdPlanner.Pages.IndexModel

@{
    ViewData["Title"] = "Week";
}

@if (TempData["OutsideAvailabilityWarning"] is string warn)
{
    <div class="panel mb-4">
        <div class="panel-body">
            <p class="text-sm">@warn</p>
        </div>
    </div>
}

<div class="page">
    <div class="page-header flex items-center justify-between gap-2">
        <div>
            <h1 class="page-title">This week</h1>
            <p class="text-muted text-sm">
                @Model.WeekStart.ToString("dd MMM yyyy") – @Model.WeekEnd.ToString("dd MMM yyyy")
            </p>
        </div>

        <div class="flex items-center gap-2">
            <a class="btn btn-secondary"
               asp-page="./Index"
               asp-route-weekStart="@Model.WeekStart.AddDays(-7)">
                ◀ Previous
            </a>

            <a class="btn btn-secondary"
               asp-page="./Index"
               asp-route-weekStart="@Model.WeekStart.AddDays(7)">
                Next ▶
            </a>

            <a class="btn btn-secondary" asp-page="./Index">
                Today
            </a>
        </div>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,3fr)_minmax(0,1.5fr)]">

        <!-- ========== WEEK CALENDAR ========== -->
        <section class="panel">
            <div class="panel-body">

                <div class="week-grid border rounded overflow-hidden">
                    <div class="grid grid-cols-8">

                        <!-- TIME COLUMN -->
                        <div class="border-r">
                            <div class="border-b px-1 py-1 text-center h-[49px]"></div>

                            @foreach (var time in Model.HourSlots)
                            {
                                <div class="border-t text-xs text-muted pr-2 text-right flex items-start justify-end pt-1 min-h-[48px]">
                                    @time.ToString("HH\\:mm")
                                </div>
                            }
                        </div>

                        <!-- DAY COLUMNS -->
                        @foreach (var day in Model.Days)
                        {
                            var dayBlocks = Model.ScheduleBlocks
                                .Where(b => b.Date == day)
                                .OrderBy(b => b.StartHalfHourIndex)
                                .ToList();

                            <div class="border-r last:border-r-0 min-w-0">

                                <!-- DAY HEADER -->
                                <div class="border-b px-1 py-1 text-center">
                                    <div class="text-xs text-muted">@day.ToString("ddd")</div>
                                    <div class="font-semibold">@day.ToString("dd MMM")</div>
                                </div>

                                <!-- 30‑minute GRID (06:00–22:00) -->
                                <div class="relative grid h-[768px] overflow-hidden"
                                     style="grid-template-rows: repeat(32, minmax(0, 1fr));">

                                    @{
                                        var i = 0;
                                        while (i < 32)
                                        {
                                            var block = dayBlocks.FirstOrDefault(b => b.StartHalfHourIndex == i);

                                            if (block != null)
                                            {
                                                var rowStart = block.StartHalfHourIndex + 1;
                                                var halfHours = block.HalfHourSpan;
                                                if (halfHours < 1) { halfHours = 1; }

                                                var borderColor = !string.IsNullOrEmpty(block.AssigneeColor)
                                                    ? block.AssigneeColor
                                                    : "var(--planner-border-subtle, rgba(148, 163, 184, 0.7))";

                                                var tooltip = $"{block.TaskName} • {block.AssigneeName} • {block.StartLocalTime:HH\\:mm}–{block.StartLocalTime.Add(block.Duration):HH\\:mm}";

                                                <a href="@Url.Page("/Schedules/Edit", new {
                                                        id = block.Id,
                                                        returnUrl = Url.Page("/Index", new { weekStart = Model.WeekStart.ToString("yyyy-MM-dd") })
                                                    })"
                                                   class="schedule-block @(block.IsDoubleBooked ? "schedule-block--double-booked" : "")"
                                                   title="@tooltip"
                                                   style="grid-row: @rowStart / span @halfHours; border-color: @borderColor; overflow:hidden;">

                                                    <!-- Title (always visible) -->
                                                    <div class="schedule-block__title overflow-hidden text-ellipsis whitespace-nowrap"
                                                         title="@block.TaskName">
                                                        @block.TaskName
                                                    </div>

                                                    <!-- 60 min+: assignee -->
                                                    @if (halfHours >= 2 && !string.IsNullOrEmpty(block.AssigneeName))
                                                    {
                                                        <div class="schedule-block__meta text-muted text-xs overflow-hidden text-ellipsis whitespace-nowrap"
                                                             title="@block.AssigneeName">
                                                            @block.AssigneeName
                                                        </div>
                                                    }

                                                    <!-- 90 min+: duration -->
                                                    @if (halfHours >= 3)
                                                    {
                                                        <div class="schedule-block__meta text-muted text-xs overflow-hidden text-ellipsis whitespace-nowrap"
                                                             title="@($"{block.StartLocalTime:HH\\:mm} – {block.StartLocalTime.Add(block.Duration):HH\\:mm}")">
                                                            @block.StartLocalTime.ToString("HH\\:mm")
                                                            –
                                                            @block.StartLocalTime.Add(block.Duration).ToString("HH\\:mm")
                                                        </div>
                                                    }
                                                </a>

                                                i += halfHours;
                                            }
                                            else
                                            {
                                                bool isHourLine = i % 2 == 0;
                                                <div class="@(isHourLine ? "border-t" : "") h-[24px] w-full"></div>;
                                                i++;
                                            }
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </section>

        <!-- ========== SIDEBAR ========== -->
        <aside class="panel">
            <div class="panel-body">

                <div class="flex items-center justify-between mb-2">
                    <h2 class="text-base font-semibold">Tasks this week</h2>

                    <button class="btn btn-secondary text-xs"
                            hx-get="/healthz"
                            hx-target="#week-health-status"
                            hx-swap="innerHTML">
                        Check health
                    </button>
                </div>

                <div id="week-health-status" class="text-muted text-xs mb-4">
                    System status not checked yet.
                </div>

                <!-- OVERDUE -->
                @if (Model.OverdueTasks.Any())
                {
                    <h3 class="text-sm font-semibold mb-1">Overdue</h3>
                    <ul class="mb-3 space-y-1">
                        @foreach (var task in Model.OverdueTasks)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <a class="action-link"
                                   asp-page="/Tasks/Edit"
                                   asp-route-id="@task.Id">
                                    @task.Name
                                </a>

                                @if (task.AssigneeId != null)
                                {
                                    <a class="action-link text-xs"
                                       asp-page="/Schedules/Create"
                                       asp-route-taskId="@task.Id"
                                       asp-route-returnUrl="@Url.Page("/Index", new { weekStart = Model.WeekStart.ToString("yyyy-MM-dd") })">
                                        Plan
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                }

                <!-- DUE THIS WEEK -->
                @if (Model.DueThisWeekTasks.Any())
                {
                    <h3 class="text-sm font-semibold mb-1">Due this week</h3>
                    <ul class="mb-3 space-y-1">
                        @foreach (var task in Model.DueThisWeekTasks)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <a class="action-link"
                                   asp-page="/Tasks/Edit"
                                   asp-route-id="@task.Id">
                                    @task.Name
                                </a>

                                @if (task.AssigneeId != null)
                                {
                                    <a class="action-link text-xs"
                                       asp-page="/Schedules/Create"
                                       asp-route-taskId="@task.Id"
                                       asp-route-returnUrl="@Url.Page("/Index", new { weekStart = Model.WeekStart.ToString("yyyy-MM-dd") })">
                                        Plan
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                }

                <!-- UNASSIGNED TASKS -->
                @if (Model.UnassignedTasks.Any())
                {
                    <h3 class="text-sm font-semibold mb-1">Unassigned</h3>
                    <ul class="space-y-1">
                        @foreach (var task in Model.UnassignedTasks)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <a class="action-link"
                                   asp-page="/Tasks/Edit"
                                   asp-route-id="@task.Id">
                                    @task.Name
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </aside>
    </div>
</div>